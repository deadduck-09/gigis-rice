//=======//
//Outputs//
//=======//
output "eDP-1" {
  // Uncomment to disable this output
  // off

  mode "1366x768@60.004"

  // Can use integer or fractional scale, eg: 1.5 for 150%
  scale 1

  //Rotate the screen
  // normal, 90, 180, 270, flipped, flipped-90, flipped-180 and flipped-270.
  transform "normal"

  position x=1280 y=0
}
